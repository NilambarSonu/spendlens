# ============================================
# SpendLens - Environment Variables
# Copy this file and fill in your values
# ============================================

# Neon Postgres (Required - main database)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@your-neon-host/neondb?sslmode=require

# Google Gemini AI (Required - AI summary generation)
GEMINI_API_KEY=your_gemini_api_key_from_ai_studio

# Resend Email (Required - transactional email)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# App URL (Update to your production domain on Vercel)
NEXT_PUBLIC_APP_URL=https://spendlens.vercel.app

# Auth Secret (Required - JWT token signing)
AUTH_SECRET=your_secure_random_32_char_secret_here
